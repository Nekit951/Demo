<Window x:Class="WpfApp3.CategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="CategoryWindow" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="dataGrid" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Button x:Name="AddCategory" Content="Добавить" HorizontalAlignment="Left" Margin="129,231,0,0" VerticalAlignment="Top" Click="AddCategory_Click"/>
        <Button x:Name="DelCategory" Content="Удалить" HorizontalAlignment="Left" Margin="238,231,0,0" VerticalAlignment="Top" Click="DelCategory_Click"/>
        <TextBox x:Name="InputCategory" HorizontalAlignment="Left" Margin="387,231,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>

    </Grid>
</Window>
