<Window x:Class="WpfApp3.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="UserWindow" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="dataGrid" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Button x:Name="DelUser" Content="Удалить" HorizontalAlignment="Left" Margin="552,335,0,0" VerticalAlignment="Top" Click="DelUser_Click"/>
        <TextBox x:Name="InputName" HorizontalAlignment="Left" Margin="203,207,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="InputPass" HorizontalAlignment="Left" Margin="427,207,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label x:Name="Name" Content="Имя" HorizontalAlignment="Left" Margin="141,203,0,0" VerticalAlignment="Top" RenderTransformOrigin="1.133,0.563"/>
        <Label x:Name="Pass" Content="Пароль" HorizontalAlignment="Left" Margin="367,203,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
