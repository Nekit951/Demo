<Window x:Class="WpfApp3.Auth"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="Auth" Height="450" Width="800">
    <Grid>
        <Label Content="Вход" HorizontalAlignment="Center" Margin="0,71,0,0" VerticalAlignment="Top"/>
        <Label Content="Имя" HorizontalAlignment="Left" Margin="264,159,0,0" VerticalAlignment="Top"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="255,235,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="InputName" HorizontalAlignment="Left" Margin="432,159,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="InputPass" HorizontalAlignment="Left" Margin="432,243,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Button Content="Войти" HorizontalAlignment="Left" Margin="372,313,0,0" VerticalAlignment="Top" Click="Button_Click"/>
        <Label x:Name="RegAuth" Content="Регистрация" HorizontalAlignment="Left" Margin="351,368,0,0" VerticalAlignment="Top" MouseDown="RegLabel"/>

    </Grid>
</Window>
